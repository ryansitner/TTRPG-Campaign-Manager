@page "/maps/view/{mapID:int}"
@using TTRPGManager.Models
@using Microsoft.EntityFrameworkCore
@inject TTRPGManager.Data.CampaignDbContext Db
@inject NavigationManager NavManager

<h3></h3>

@if (currentMap == null)
{
	<button class="btn btn-primary" type="button" disabled>
		<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
		Loading Map Data...
	</button>
} else
{
	<div class="d-flex flex-column text-white" style="height: calc(100vh - 40px);">

		<div class="row">
			<div class="col">
				<div class="d-flex justify-content-start">
					<a href="/maps/@currentMap.Type" class="btn btn-dark btn-icon me-2" aria-label="Back to Map Directory">
						<img src="/images/BackIcon.png" alt="Back Icon" class="header-icon" />
					</a>
					<h2 class="mt-3">@currentMap.Name</h2>
				</div>
			</div>

			<div class="col">
				<div class="d-flex justify-content-end">
					<button class="btn btn-primary type=button mt-3" @onclick="GoToEditPage">Edit Map Details</button>
				</div>
			</div>
		</div>

		<InteractiveImageViewer ImageSource="@currentMap.Image" />

		<div class="row mt-3 text-center">
			<div class="col">
				<button class="btn btn-primary" type="button" @onclick="ToggleDetailDescription">Toggle DM Details</button>
			</div>

			<div class="col">
				<p>Grid Size: @CheckSetGridSize()</p>
			</div>

			<div class="col">
				<p><b>@SafeToShowPlayers()</b> to show players.</p>
			</div>

		</div>

		@if (ToggleDescription)
		{
			@if (!string.IsNullOrEmpty(currentMap.Description))
			{
				<div class="mt-2">
					<p><strong>Description: </strong><br /> @currentMap.Description</p>
				</div>
			} else {
				<div class="mt-2">
					<p><strong>Description: </strong><br /> No description set...</p>
				</div>
			}
		}
			

	</div>


}

@code {

	[Parameter]
	public int mapID { get; set; }

	private Map? currentMap;
	private bool ToggleDescription = true;

	protected override async Task OnInitializedAsync()
	{
		currentMap = await Db.Maps.FirstOrDefaultAsync(m => m.Id == mapID);
	}

	private string CheckSetGridSize ()
	{
		return string.IsNullOrWhiteSpace(currentMap.GridScale) ? "Not Specified" : currentMap.GridScale;
	}

	private string SafeToShowPlayers()
	{
		return currentMap.IsPlayerSafe ? "Safe" : "Not Safe";
	}

	private void ToggleDetailDescription()
	{
		ToggleDescription = !ToggleDescription;
	}

	private void GoToEditPage()
	{
		NavManager.NavigateTo($"/maps/edit/{currentMap.Id}");
	}
}
