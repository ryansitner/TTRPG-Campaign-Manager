@page "/items/create"
@page "/items/edit/{itemID:int}"
@using TTRPGManager.Models
@using Microsoft.EntityFrameworkCore

@inject TTRPGManager.Data.CampaignDbContext Db
@inject NavigationManager NavManager

@if (itemID.HasValue)
{
    <h3>Edit Item: @newItem.Name</h3>
} else {
    <h3 class="text-capitalize">Item Create Form</h3>
}

<EditForm EditContext="itemContext" class="d-flex flex-column" style="height: calc(100vh - 60px);">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="card p-4 bg-dark text-white flex-grow-1" style="overflow-y: auto; overflow-x: hidden;">

        <div class="row mb-3">
            <div class="col-3">
                <label>Item Type:</label>
                <InputSelect @bind-Value=newItem.Type class="form-select">
                    <option value="">-- Select an Item Type --</option>
                    @foreach (var type in Enum.GetValues<ItemType>())
                    {
                        <option value="@type">@FormatEnumName(type.ToString())</option>
					}
                </InputSelect>
            </div>

            <div class="col-3">
                <label>Item Rarity:</label>
                <InputSelect @bind-Value=newItem.Rarity class="form-select">
                    <option value="">-- Select an Item Rarity --</option>
                    @foreach (var type in Enum.GetValues<ItemRarity>())
                    {
                        <option value="@type">@FormatEnumName(type.ToString())</option>
                    }
                </InputSelect>
            </div>

            <div class="col-6">
                <label>Name:</label>
                <InputText @bind-Value=newItem.Name class="form-control" placeholder="+2 Flaming Longsword of the Phoenix" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-4">
                <label>Weight:</label>
                <InputNumber @bind-Value=newItem.Weight class="form-control" step="0.1" />
            </div>

            <div class="col-8">
                <label>Cost:</label>
                <div class="d-flex align-items-center gap-2">
                    <span>PP: </span>
                    <InputNumber @bind-Value=inputPlatinum class="form-control" min="0" style="width: 80px;" />

                    <span>GP: </span>
                    <InputNumber @bind-Value=inputGold class="form-control" min="0" style="width: 80px;" />

                    <span>SP: </span>
                    <InputNumber @bind-Value=inputSilver class="form-control" min="0" style="width: 80px;" />

                    <span>CP: </span>
                    <InputNumber @bind-Value=inputCopper class="form-control" min="0" style="width: 80px;" />
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <label>Description:</label>
                <InputTextArea @bind-Value=newItem.Description class="form-control" />
            </div>
        </div>

        <div class="mb-3 border border-secondary rounded p-3">
            <label class="fw-bold mb-2">Upload Item Image: <span class="text-danger">*</span></label>

            @* Scenario 1: No image uploaded yet. Show the file input. *@
            @if (string.IsNullOrWhiteSpace(newItem.Image))
            {
                <button type="button" class="btn btn-outline-info w-100 mb-1" @onclick="PickImageNative">Browse for Item Image...</button>
            }
            @* Scenario 2: Image exists. Show success banner and preview. *@
            else
            {
                <div class="d-flex flex-column gap-3">
                    <div class="alert alert-success p-2 mb-0 d-flex align-items-center justify-content-between" role="alert">
                        <div>
                            <span class="oi oi-check me-2" aria-hidden="true"></span>
                            <strong>Item Image Uploaded Successfully!</strong>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearPhoto">Remove / Change</button>
                    </div>

                    <img src="@newItem.Image" alt="Item Preview" class="img-fluid rounded border border-dark" style="max-height: 250px; object-fit: contain;" />
                </div>
            }
        </div>

        <div class="row">
            <div class="col-6 mb-3 d-flex justify-content-center align-items-center gap-2">
                <label>Magical Item?</label>
				<InputCheckbox @bind-Value=newItem.IsMagical class="form-check-input" />
            </div>

            <div class="col-6 mb-3 d-flex justify-content-center align-items-center gap-2">
                <label>Requires Attunement?</label>
                <InputCheckbox @bind-Value=newItem.RequiresAttunement class="form-check-input" />
            </div>
        </div>

        @if(newItem.Type == ItemType.Weapon)
        {
            <div class="mb-3 border border-secondary rounded p-3">
                <label class="fw-bold mb-2">Weapon Stats</label>
                <div class="row">
                    <div class="col-4">
                        <label>Damage Type:</label>
                        <InputSelect @bind-Value=newItem.DamageType class="form-select">
                            <option value="">-- Select Damage Type --</option>
                            @foreach (var type in Enum.GetValues<DamageType>())
                            {
                                <option value="@type">@FormatEnumName(type.ToString())</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-3">
                        <label>Damage Dice:</label>
                        <InputText @bind-Value=newItem.DamageDice class="form-control" placeholder="e.g., 1d8" />
                    </div>

                    <div class="col-3">
                        <label>Normal Range: <span class="text-muted">(ft.)</span></label>
                        <InputNumber @bind-Value=newItem.NormalRange class="form-control" min="0" />
                    </div>

                    <div class="col-2">
                        <label>Max Range: <span class="text-muted">(ft.)</span></label>
                        <InputNumber @bind-Value=newItem.MaxRange class="form-control" min="0" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 d-flex justify-content-start align-content-center mt-3 ms-1">
                        <label class="me-2">Is Finesse Weapon?</label>
                        <InputCheckbox @bind-Value=newItem.IsFinesseWeapon class="form-check-input" />
                    </div>
                </div>
            </div>
        }

        @if (newItem.Type == ItemType.Armor)
        {
            <div class="mb-3 border border-secondary rounded p-3">
                <div class="row">
                    <label class="fw-bold mb-2">Armor Stats</label>
                    <div class="col-6">
                        <label>Armor Type:</label>
                        <InputSelect @bind-Value=newItem.ArmorType class="form-select">
                            <option value="">-- Select Armor Type --</option>
                            @foreach (var type in Enum.GetValues<ArmorType>())
                            {
                                <option value="@type">@FormatEnumName(type.ToString())</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <label>Armor Class Value:</label>
                        <InputNumber @bind-Value=newItem.ArmorClassValue class="form-control" min="0" />
                    </div>
                </div>
            </div>
        }

        @if (newItem.Type == ItemType.Shield)
        {
            <div class="mb-3 border border-secondary rounded p-3">
                <div class="row">
                    <label class="fw-bold mb-2">Shield Stats</label>

                    <div class="col-6">
                        <label>Armor Class Value:</label>
                        <InputNumber @bind-Value=newItem.ArmorClassValue class="form-control" min="0" />
                    </div>
                </div>
            </div>
        }


    </div>

    <div class="mt-auto pt-3 pb-3 border-top d-flex justify-content-between align-items-center">
        <button type="button" class="btn btn-danger" @onclick="CancelCreation">Cancel</button>

        @if (itemID.HasValue)
        {
            <button type="button" class="btn btn-primary" @onclick="SaveItem">Save Changes</button>
        }
        else
        {
            <button type="button" class="btn btn-success" @onclick="SaveItem">Save Item</button>
        }

    </div>

</EditForm>

@code {

    [Parameter]
    public int? itemID { get; set; }

    private Item newItem = new Item();

    private int inputPlatinum = 0;
    private int inputGold = 0;
    private int inputSilver = 0;
    private int inputCopper = 0;

    private EditContext itemContext;

    protected override async Task OnInitializedAsync()
    {
        if (itemID.HasValue)
        {
            // Confirm that the itemID parameter is valid and fetch the item data
            newItem = await Db.Items.FirstOrDefaultAsync(i => i.Id == itemID);
            if (newItem == null)
            {
                // Handle the case where the itemID is invalid (e.g., navigate back or show an error message)
                NavManager.NavigateTo("/items");
            }
        }

        itemContext = new EditContext(newItem);
    }

    // Add spaces to enum names that contain multiple words (e.g. "SlightOfHand" becomes "Slight Of Hand")
    private string FormatEnumName(string myString)
    {
        return System.Text.RegularExpressions.Regex.Replace(myString, "([A-Z])", " $1").Trim();
    }

    private async Task PickImageNative()
    {
        try
        {
            // Trigger the Native Windows/Mac File Picker
            var result = await Microsoft.Maui.Storage.FilePicker.Default.PickAsync(new PickOptions
            {
                PickerTitle = "Select an Item Image",
                FileTypes = FilePickerFileType.Images
            });

            // If they actually picked a file (and didn't hit cancel)
            if (result != null)
            {
                // Read the file directly from the operating system
                using var stream = await result.OpenReadAsync();
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);

                // Convert the raw bytes into our Base64 string for the database
                var buffer = memoryStream.ToArray();
                var base64 = Convert.ToBase64String(buffer);

                // Save it to the model (using the native ContentType like image/png)
                newItem.Image = $"data:{result.ContentType};base64,{base64}";
            }
        }
        catch (Exception ex)
        {
            // Failsafes silently if the user closes the window without picking anything
            Console.WriteLine($"Image picking failed: {ex.Message}");
        }
    }

    private void ClearPhoto()
    {
        // Resets the string to empty, triggering Scenario 1 to show the upload button again
        newItem.Image = string.Empty;
    }

    private string SelectDefaultImage(ItemType itemType)
    {
        switch (itemType)
        {
            case ItemType.AdventuringGear:
                return "/images/ItemDefaults/AdventuringGearIcon.png";
            case ItemType.Armor:
                return "/images/ItemDefaults/ArmorIcon.png";
            case ItemType.Jewelry:
                return "/images/ItemDefaults/JewelryIcon.png";
            case ItemType.Potion:
                return "/images/ItemDefaults/PotionIcon.png";
            case ItemType.Scroll:
                return "/images/ItemDefaults/ScrollIcon.png";
            case ItemType.Shield:
                return "/images/ItemDefaults/ShieldIcon.png";
            case ItemType.Treasure:
                return "/images/ItemDefaults/TreasureIcon.png";
            case ItemType.Wand:
                return "/images/ItemDefaults/WandIcon.png";
            case ItemType.Weapon:
                return "/images/ItemDefaults/WeaponIcon.png";
            case ItemType.WondrousItem:
                return "/images/ItemDefaults/WondrousItemIcon.png";
            default:
                return "/images/ItemDefaults/TreasureIcon.png";
        }
    }

    private async Task SaveItem()
    {
        if (itemContext.Validate())
        {
            if (string.IsNullOrWhiteSpace(newItem.Image))
            {
                newItem.Image = SelectDefaultImage(newItem.Type);
            }

            newItem.CostInCopper = (inputPlatinum * 1000) + (inputGold * 100) + (inputSilver * 10) + inputCopper;

            if (itemID.HasValue)
            {
				Db.Items.Update(newItem);
            } else
            {
                Db.Items.Add(newItem);
            }

            await Db.SaveChangesAsync();
            NavManager.NavigateTo($"/items");

        }
    }

    private void CancelCreation()
    {
        NavManager.NavigateTo($"/items");
    }

}
